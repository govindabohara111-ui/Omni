datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Project {
  id          String    @id @default(cuid())
  name        String
  containerId String? // Docker container ID
  hostPort    Int? // Mapped port for live preview
  messages    Message[]
  createdAt   DateTime  @default(now())
}

model Message {
  id        String   @id @default(cuid())
  role      String // 'user' | 'assistant' | 'tool'
  content   String
  agentName String? // e.g., 'Orchestrator', 'Frontend Dev'
  toolCalls Json? // Store raw tool call data for UI rendering
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
